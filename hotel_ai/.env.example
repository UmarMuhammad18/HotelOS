# Copy to .env and fill in real values. Never commit .env.

# --- LLM provider ---
# Choose one of: groq | gemini | anthropic | fake
# Leave blank to auto-detect from whichever API key is set below
# (preference order: groq > gemini > anthropic > fake).
LLM_PROVIDER=groq

# Override the default model for the selected provider (optional).
# Defaults: llama-3.1-8b-instant (groq), gemini-2.0-flash (gemini),
#           claude-sonnet-4-6 (anthropic).
# Groq alternatives: llama-3.3-70b-versatile, mixtral-8x7b-32768.
LLM_MODEL=

# Groq (free tier, no card, globally available).
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Gemini (free tier, but region-restricted — may fail with "limit: 0").
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic (paid — leave blank unless you have a key).
ANTHROPIC_API_KEY=

ENVIRONMENT=development
LOG_LEVEL=INFO

# Where guest memory lives. For MVP we use a JSON file on disk.
GUEST_MEMORY_PATH=./data/guest_memory.json

# Backend callback URLs (owned by the general backend team).
BACKEND_NOTIFICATIONS_URL=http://localhost:4000/internal/notifications
BACKEND_TASKS_URL=http://localhost:4000/internal/tasks
INTERNAL_API_TOKEN=replace-me
