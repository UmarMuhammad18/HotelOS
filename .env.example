# Create React App — copy to `.env.local` for local dev, or set in Vercel project settings.

# HTTP API (no trailing slash). Example production: https://hotelos-api.onrender.com
REACT_APP_API_URL=http://localhost:8080

# Optional overrides (otherwise derived from REACT_APP_API_URL)
# REACT_APP_WS_URL=wss://hotelos-api.onrender.com
# REACT_APP_CHAT_WS_URL=wss://hotelos-api.onrender.com/chat
